{
  "manifest_version": 3,
  "name": "OpenClaw Browser Relay",
  "description": "Claude-style quick attach flow for OpenClaw browser relay.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "OpenClaw Relay",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
