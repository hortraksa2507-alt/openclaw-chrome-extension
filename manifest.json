{
  "manifest_version": 3,
  "name": "OpenClaw Browser Relay",
  "description": "OpenClaw Browser Mode v4: relay handshake, safe command execution, persistent tab memory, and side panel assistant.",
  "version": "0.4.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "sidePanel",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "OpenClaw Browser Mode",
    "default_popup": "src/popup.html"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
